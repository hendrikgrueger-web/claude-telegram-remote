# Telegram Bot Token (von @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Deine Telegram User-ID (Integer) — ermittelbar via @userinfobot
ALLOWED_USER_ID=123456789

# Standard-Arbeitsverzeichnis für neue Workspaces
DEFAULT_WORKSPACE_DIR=~/Coding

# Claude Subprocess Timeout in Sekunden
CLAUDE_TIMEOUT_SECONDS=300

# Absoluter Pfad zur Claude CLI (wird von install.sh automatisch gesetzt)
# CLAUDE_BIN=

# Workaround: Deaktiviert abgelaufene Beta-Header in der Claude CLI
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
